# =============================================================================
# Vibe Platform - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://vibe:vibe_dev_password@localhost:5432/vibe
TEST_DATABASE_URL=postgresql://vibe_test:vibe_test@localhost:5433/vibe_test

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
TEST_REDIS_URL=redis://localhost:6380/0

# -----------------------------------------------------------------------------
# Firebase Authentication
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
# Optional: Path to service account JSON for admin operations
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# Primary provider (Groq)
GROQ_API_KEY=gsk_your_groq_api_key

# Fallback provider (OpenAI)
OPENAI_API_KEY=sk-your_openai_api_key

# Optional: Override defaults
# LLM_PRIMARY_PROVIDER=groq
# LLM_FALLBACK_ENABLED=true
# LLM_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
# Optional: Personal Access Token for higher rate limits
# GITHUB_PAT=ghp_your_github_token

# -----------------------------------------------------------------------------
# Email Notifications (Brevo/Sendinblue)
# -----------------------------------------------------------------------------
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Vibe Platform

# -----------------------------------------------------------------------------
# File Storage (GCS or local)
# -----------------------------------------------------------------------------
# For production: GCS
# GCS_BUCKET_NAME=your-bucket-name
# GCS_CREDENTIALS_PATH=/path/to/gcs-credentials.json

# For local development: local filesystem
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Secret key for signing (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-generate-this

# -----------------------------------------------------------------------------
# Rate Limits (per architecture-decisions.md)
# -----------------------------------------------------------------------------
RATE_LIMIT_API_DEFAULT=100/minute
RATE_LIMIT_SUBMISSIONS=5/hour
RATE_LIMIT_AUTH=10/minute

# -----------------------------------------------------------------------------
# LLM Budget Limits (per org, in USD)
# -----------------------------------------------------------------------------
LLM_DAILY_BUDGET_DEFAULT=10.00
LLM_MONTHLY_BUDGET_DEFAULT=100.00
LLM_BUDGET_WARN_THRESHOLD=0.8
LLM_BUDGET_HARD_STOP_THRESHOLD=1.0

# -----------------------------------------------------------------------------
# Worker Settings
# -----------------------------------------------------------------------------
WORKER_QUEUE_NAME=scoring
CLONE_TIMEOUT_SECONDS=60
JOB_TIMEOUT_SECONDS=180
STUCK_JOB_THRESHOLD_MINUTES=5

# -----------------------------------------------------------------------------
# Monitoring & Alerts
# -----------------------------------------------------------------------------
# Optional: Slack webhook for critical alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Alert thresholds
ALERT_QUEUE_DEPTH_THRESHOLD=100
ALERT_LLM_FAILURE_RATE_THRESHOLD=0.10
